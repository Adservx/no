{
  "name": "manikant-engineering-hub",
  "private": true,
  "description": "A comprehensive web platform for Sub-Electrical Engineers featuring a social community, PDF library, and study materials management system",
  "homepage": "https://github.com/Adservx/no#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Adservx/no.git"
  },
  "author": "Adservx",
  "license": "MIT",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --config config/vite.config.ts",
    "prebuild": "rimraf dist",
    "build": "tsc --project config/tsconfig.json && vite build --config config/vite.config.ts",
    "preview": "vite preview --config config/vite.config.ts",
    "start": "serve -s dist",
    "vercel-build": "npm run build",
    "upload-pdfs": "tsx scripts/uploadToR2.ts",
    "sync-metadata": "tsx scripts/syncR2ToDb.ts",
    "migrate-metadata": "tsx scripts/migrateToFileMetadata.ts",
    "test": "vitest --config config/vitest.config.ts",
    "test:ui": "vitest --ui --config config/vitest.config.ts",
    "test:coverage": "vitest --coverage --config config/vitest.config.ts",
    "lint": "eslint src --ext .ts,.tsx --config config/eslint.config.js",
    "lint:fix": "eslint src --ext .ts,.tsx --fix --config config/eslint.config.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.917.0",
    "@supabase/supabase-js": "^2.76.1",
    "@types/dompurify": "^3.0.5",
    "dotenv": "^17.2.3",
    "heic2any": "^0.0.4",
    "jspdf": "^4.2.1",
    "pdfjs-dist": "^5.3.31",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-dropzone": "^14.3.8",
    "react-pdf": "^10.0.1",
    "react-router-dom": "^7.9.6",
    "serve": "^14.2.1"
  },
  "devDependencies": {
    "@babel/plugin-transform-react-jsx": "^7.27.1",
    "@babel/preset-env": "^7.28.0",
    "@babel/preset-react": "^7.27.1",
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.0.10",
    "@types/react": "^18.3.20",
    "@types/react-dom": "^18.3.6",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/ui": "^4.1.2",
    "dompurify": "^3.3.3",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "happy-dom": "^20.8.9",
    "jsdom": "^29.0.1",
    "rimraf": "^5.0.10",
    "tsx": "^4.20.6",
    "typescript": "^5.4.2",
    "vite": "^6.3.5",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-pwa": "^1.0.1",
    "vitest": "^4.1.2"
  }
}
